{
  "name": "@dong-/cdxx",
  "version": "0.2.0",
  "description": "Multi-profile wrapper and live quota failover for Codex CLI",
  "type": "module",
  "bin": {
    "cdxx": "src/cli.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "check": "node --check src/*.js",
    "build:native": "node scripts/build-native.cjs",
    "check:native-package": "node scripts/check-native-package.cjs",
    "preinstall": "node scripts/preinstall.cjs",
    "prepack": "npm run check && npm test && npm run check:native-package"
  },
  "files": [
    "bin/cdxx-supervisor",
    "bin/cdxx-supervisor-darwin-arm64",
    "bin/cdxx-supervisor-linux-arm64",
    "src",
    "scripts/*.cjs",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "codex",
    "openai",
    "cli",
    "quota",
    "account-switcher"
  ],
  "author": "Dongwook Chan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dongwook-chan/codexx.git"
  },
  "bugs": {
    "url": "https://github.com/dongwook-chan/codexx/issues"
  },
  "homepage": "https://github.com/dongwook-chan/codexx#readme",
  "engines": {
    "node": ">=20"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "cpu": [
    "arm64"
  ]
}
